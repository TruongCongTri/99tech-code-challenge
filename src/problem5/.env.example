# Server Configuration
NODE_ENV=development
PORT=3000

# Database Connection (Development)
# Replace <USER>, <PASSWORD>, and <DB_NAME> with your local Postgres credentials
DATABASE_URL="postgresql://<USER>:<PASSWORD>@localhost:5432/<DB_NAME>?schema=public"

# Authentication & Security
JWT_SECRET="your_development_jwt_secret_here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your_development_refresh_secret_here"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS=12

# CORS Configuration (Next.js Frontend)
CLIENT_URL="http://localhost:3000"